# ═══ VÉRITAS Academy — Configuration LWS (LiteSpeed/Apache) v1.2 ═══
# Sécurité renforcée + SEO + Performance

# ─────────────────────────────────────────────────────────
# 1. Redirection HTTPS forcée (anti-MITM)
# ─────────────────────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Optionnel : www → non-www
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# index.php sert app.html avec headers no-cache PHP
DirectoryIndex index.php index.html

# ─────────────────────────────────────────────────────────
# 2. Headers de sécurité (renforcés v1.2)
# ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Force HTTPS pendant 1 an (HSTS)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Anti-MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Anti-clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"

  # XSS protection (legacy)
  Header always set X-XSS-Protection "1; mode=block"

  # Référent
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions (caméra/micro/géoloc bloqués, paiement autorisé)
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self), interest-cohort=()"

  # Cross-origin embedder/opener
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-site"
</IfModule>

# ─────────────────────────────────────────────────────────
# 3. Bloquer les User-Agents malveillants (scanners, bots)
# ─────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} (sqlmap|nikto|nessus|acunetix|netsparker|wpscan|fimap|havij|w3af|skipfish|masscan|nmap) [NC]
  RewriteRule .* - [F,L]

  # Bloquer les patterns d'injection SQL classiques
  RewriteCond %{QUERY_STRING} (union[\s+]+select|insert[\s+]+into|drop[\s+]+table|update[\s+]+set|delete[\s+]+from) [NC,OR]
  RewriteCond %{QUERY_STRING} (<script|javascript:|vbscript:|onload=|onerror=|onmouseover=) [NC,OR]
  RewriteCond %{QUERY_STRING} (\.\./|\.\.\\|%2e%2e) [NC]
  RewriteRule .* - [F,L]

  # Bloquer accès direct aux fichiers de config sensibles
  RewriteRule ^(api/payment_config\.php|api/config\.php|api/config_sync\.php)$ - [F,L]
  RewriteRule ^api/data/_security_log\.txt$ - [F,L]
  RewriteRule ^api/data/_access_log\.txt$ - [F,L]
</IfModule>

# ─────────────────────────────────────────────────────────
# 4. Compression (Gzip / Brotli)
# ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
  AddOutputFilterByType DEFLATE text/xml application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE image/svg+xml application/manifest+json
</IfModule>

# ─────────────────────────────────────────────────────────
# 5. Cache Control intelligent
# ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # HTML : jamais mis en cache
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "Thu, 01 Jan 1970 00:00:00 GMT"
    Header set Surrogate-Control "no-store"
    Header set CDN-Cache-Control "no-store"
    Header set X-LiteSpeed-Cache-Control "no-cache"
  </FilesMatch>

  # Assets statiques : cache 1 an
  <FilesMatch "\.(css|js|woff2|jpg|jpeg|png|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Sitemap/robots : cache 1 jour
  <FilesMatch "\.(xml|txt)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# ─────────────────────────────────────────────────────────
# 6. Bloquer fichiers sensibles (renforcé)
# ─────────────────────────────────────────────────────────
<FilesMatch "(^\.|\.env|\.git|\.htaccess|\.htpasswd|\.sql|\.bak|\.swp|\.old|\.log|composer\.|package\.|payment_config\.php|_security_log|_access_log)">
  Require all denied
</FilesMatch>

<FilesMatch "\.(md|gitignore|htaccess|htpasswd|sql|bak|log)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Désactiver le listing des répertoires
Options -Indexes

# ─────────────────────────────────────────────────────────
# 7. SEO — pages d'erreur et MIME types
# ─────────────────────────────────────────────────────────
ErrorDocument 404 /index.html
ErrorDocument 403 /index.html

AddType application/manifest+json .webmanifest
AddType image/webp .webp
AddType application/font-woff2 .woff2
AddType video/mp4 .mp4
AddType video/webm .webm
AddType video/ogg .ogv .ogg

# ─────────────────────────────────────────────────────────
# 8. Upload PHP — limites pour vidéos
# ─────────────────────────────────────────────────────────
<IfModule mod_php.c>
  php_value upload_max_filesize 100M
  php_value post_max_size 105M
  php_value max_execution_time 300
  php_value max_input_time 300
</IfModule>
<IfModule lsapi_module>
  php_value upload_max_filesize 100M
  php_value post_max_size 105M
  php_value max_execution_time 300
  php_value max_input_time 300
</IfModule>

# ─────────────────────────────────────────────────────────
# 9. Cacher la version Apache / PHP (security through obscurity)
# ─────────────────────────────────────────────────────────
ServerSignature Off
<IfModule mod_headers.c>
  Header unset X-Powered-By
  Header unset Server
</IfModule>
