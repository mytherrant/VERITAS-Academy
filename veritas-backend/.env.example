# ============================================================
# VÉRITAS Backend — Configuration
# Copiez ce fichier en .env et remplissez vos vraies valeurs
# ============================================================

# Base de données PostgreSQL
DATABASE_URL=postgresql://veritas_user:MOT_DE_PASSE_ICI@localhost:5432/veritas_db

# Ou séparément :
DB_HOST=localhost
DB_PORT=5432
DB_NAME=veritas_db
DB_USER=veritas_user
DB_PASSWORD=MOT_DE_PASSE_ICI

# Serveur
PORT=3000
NODE_ENV=production

# JWT (Générez des clés uniques avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGEZ_MOI_cle_secrete_64_caracteres_minimum
JWT_REFRESH_SECRET=CHANGEZ_MOI_autre_cle_secrete_differente
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — domaine(s) autorisé(s)
CORS_ORIGIN=https://veritas-academy.cm

# Paiements (à remplir avec vos vrais identifiants)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=
ORANGE_MONEY_MERCHANT_KEY=

MTN_MOMO_API_KEY=
MTN_MOMO_API_SECRET=
MTN_MOMO_SUBSCRIPTION_KEY=

# WhatsApp Business (optionnel)
WHATSAPP_NUMBER=+237697637739

# Upload de fichiers
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
