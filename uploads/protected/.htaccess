# VÉRITAS — Store de contenu PREMIUM (Étape 2, S3 v1.2.x)
# Aucun accès HTTP DIRECT : ces fichiers ne sont servis que par api/content.php
# APRÈS vérification d'authentification et de droits (plan d'abonnement).
# Sans ceci, les médias payants seraient téléchargeables via leur URL.
Require all denied
<IfModule !mod_authz_core.c>
Order deny,allow
Deny from all
</IfModule>
# Ceinture + bretelles : bloquer aussi toute exécution serveur dans ce dossier.
Options -Indexes -ExecCGI
RemoveHandler .php .phtml .phar .cgi .pl .py
<FilesMatch "\.(php|phtml|phar|cgi|pl|py|sh|asp|aspx|jsp|exe|bat)$">
  Require all denied
</FilesMatch>
